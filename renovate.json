{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:best-practices"],
  "labels": ["dependencies"],
  "schedule": ["every 4 day"],
  "ignorePaths": [
    "**/node_modules/**",
    "**/target/**",
    ".graylog/**",
    ".m2/**"
  ],
  "packageRules": [
    {
      "description": "Group all GitHub Actions updates into a single PR.",
      "groupName": "GitHub Actions",
      "matchManagers": ["github-actions"]
    },
    {
      "description": "Keep the plugin on the Graylog 5.x line.",
      "matchPackageNames": [
        "org.graylog.plugins:graylog-plugin-parent",
        "org.graylog2:graylog2-server",
        "graylog/graylog"
      ],
      "allowedVersions": "/^5\\./",
      "groupName": "Graylog 5.x"
    }
  ],
  "customManagers": [
    {
      "customType": "regex",
      "fileMatch": ["/(^|/)\\.github/workflows/[^/]+\\.ya?ml$/"],
      "matchStrings": ["GRAYLOG_VERSION:\\s*\"(?<currentValue>[^\"]+)\""],
      "datasourceTemplate": "maven",
      "depNameTemplate": "org.graylog2:graylog2-server",
      "versioningTemplate": "maven"
    },
    {
      "customType": "regex",
      "fileMatch": [
        "/(^|/)src/integration-test/graylog/docker-compose\\.yml$/"
      ],
      "matchStrings": [
        "graylog/graylog:\\$\\{GRAYLOG_VERSION:-(?<currentValue>[^}]+)\\}"
      ],
      "datasourceTemplate": "docker",
      "depNameTemplate": "graylog/graylog"
    }
  ]
}
